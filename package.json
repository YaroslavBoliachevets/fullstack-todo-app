{
  "name": "fullstack-todo-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm --prefix frontend install && cd backend && python -m venv .venv && .\\.venv\\Scripts\\activate && pip install -r requirements.txt",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint": "npm run lint:frontend",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,html,css,json,md}": [
      "prettier --write"
    ]
  }
}
